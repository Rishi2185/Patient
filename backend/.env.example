# ─────────────────────────────────────────────────────────────────────────────
# Aarvy Patient Backend — environment configuration
# Copy to `.env` and adjust. Everything has a safe dev default EXCEPT secrets you
# should change before any non-local use.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=4100
NODE_ENV=development

# MongoDB connection.
# Leave BLANK to boot against an in-memory MongoDB (mongodb-memory-server) — no
# install, no secrets, data is ephemeral. Great for dev/demo.
# For real persistence, drop in a local URI or a MongoDB Atlas free-tier URI:
#   mongodb://127.0.0.1:27017/aarvy
#   mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/aarvy?retryWrites=true&w=majority
#
# Point this at the SAME database as the hospital-side backend (Employees/backend)
# to share the doctors/appointments/specialties collections — the schemas and ids
# are compatible, so a patient booking shows up at reception and vice-versa.
MONGODB_URI=mongodb+srv://soniasonoo82_db_user:<db_password>@cluster0.gnh3vsf.mongodb.net/

# Clinic timezone — used to compute the dayKey (YYYY-MM-DD) for every appointment.
# MUST match the hospital backend's CLINIC_TZ when sharing a database, or
# appointments near midnight land in the wrong day.
CLINIC_TZ=Asia/Kolkata

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# OTP (phone verification for sign-up & password reset).
# OTP_TTL_MINUTES — how long a requested code stays valid.
# DEMO_OTP — in non-production, this fixed code is ALWAYS accepted (parity with
# the Flutter demo, where the OTP is always 1234). Ignored in production.
OTP_TTL_MINUTES=10
DEMO_OTP=1234

# CORS — comma-separated allowlist of origins. Use * only for local development.
CORS_ORIGINS=*

# Seeded demo patient account (created by `npm run seed`). Matches the Flutter
# app's built-in demo login. Change before any real use.
DEMO_PATIENT_NAME=Demo Patient
DEMO_PATIENT_PHONE=9999999999
DEMO_PATIENT_PASS=demo1234
